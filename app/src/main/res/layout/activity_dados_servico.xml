<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Tomador e Tributação" android:textSize="22sp" android:textStyle="bold" android:textColor="#0a4f4f" android:textAlignment="center" android:layout_marginBottom="24dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CNPJ da Instituição:" android:textColor="#334155" android:textStyle="bold" />
                <EditText android:id="@+id/edtCnpj" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="number" android:textColor="#000000"/>
            </LinearLayout>
            <Button android:id="@+id/btnBuscarCnpj" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_gravity="bottom" android:backgroundTint="#c8973a" android:textColor="#ffffff" android:text="Buscar" />
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Razão Social da Empresa:" android:textColor="#334155" android:textStyle="bold" />
        <EditText android:id="@+id/edtEmpresa" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:textColor="#000000" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Endereço da Empresa:" android:textColor="#334155" android:textStyle="bold" />
        <EditText android:id="@+id/edtEnderecoEmpresa" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:textColor="#000000" android:layout_marginBottom="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Atividade Econômica (CNAE):" android:textColor="#334155" android:textStyle="bold" />
        <EditText android:id="@+id/edtCnae" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:textColor="#000000" android:layout_marginBottom="20dp"/>

        <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#cbd5e1" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Descrição do Serviço Técnico:" android:textColor="#334155" android:textStyle="bold" />
        <EditText android:id="@+id/edtDescricao" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:textColor="#000000" android:layout_marginBottom="12dp" android:hint="Ex: Auditoria contábil 05/2026"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Valor Bruto (R$):" android:textColor="#334155" android:textStyle="bold" />
                <EditText android:id="@+id/edtBruto" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="numberDecimal" android:textColor="#000000"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Valor total antes dos descontos." android:textColor="#94a3b8" android:textSize="11sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Alíquota ISS (%):" android:textColor="#334155" android:textStyle="bold" />
                <EditText android:id="@+id/edtIss" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="numberDecimal" android:text="0" android:textColor="#000000"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Varia de 2% a 5% (ou 0%)." android:textColor="#94a3b8" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="INSS Já Retido (R$):" android:textColor="#334155" android:textStyle="bold" />
                <EditText android:id="@+id/edtInssRetido" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="numberDecimal" android:text="0" android:textColor="#000000"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Evita passar do teto legal" android:textColor="#94a3b8" android:textSize="11sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Qtd. Dependentes:" android:textColor="#334155" android:textStyle="bold" />
                <EditText android:id="@+id/edtDependentes" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="number" android:text="0" android:textColor="#000000"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Dedução p/ IRRF: R$ 189,59 cada" android:textColor="#94a3b8" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <Button android:id="@+id/btnCalcular" android:layout_width="match_parent" android:layout_height="55dp" android:backgroundTint="#0a4f4f" android:textColor="#ffffff" android:text="Auditar e Calcular" android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
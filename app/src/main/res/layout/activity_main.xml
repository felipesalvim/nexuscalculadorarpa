<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f8fafc"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:src="@drawable/logo_nexus"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"
            android:adjustViewBounds="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simulador de RPA"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0a4f4f"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Valor Bruto do Serviço (R$)" android:textColor="#334155" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/edtValorBruto" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="numberDecimal" android:textColor="#000000" android:paddingHorizontal="12dp" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Número de Dependentes (IRRF)" android:textColor="#334155" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/edtDependentes" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="number" android:text="0" android:textColor="#000000" android:paddingHorizontal="12dp" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Alíquota ISS (%)" android:textColor="#334155" android:textStyle="bold" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/edtIss" android:layout_width="match_parent" android:layout_height="50dp" android:background="@android:drawable/editbox_background" android:inputType="numberDecimal" android:text="5" android:textColor="#000000" android:paddingHorizontal="12dp" android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnProsseguir"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:backgroundTint="#0a4f4f"
            android:textColor="#ffffff"
            android:text="Calcular Retenções"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>